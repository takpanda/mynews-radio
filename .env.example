# App
APP_ENV=development
API_PORT=8010
WEB_PORT=3010

# Cron (daily batch) - format: minute hour day-of-month month day-of-week (UTC)
CRON_SCHEDULE=0 21 * * *

# Backend
DATABASE_URL=sqlite:////app/data/mynews-radio.db
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3010,https://radio.beeworks.cc

# Frontend
API_BASE=http://api:8010
NEXT_PUBLIC_API_BASE=http://localhost:8010

# API key authentication (empty = disabled)
API_KEY=

# External services (DGX side)
DGX_HOST=127.0.0.1
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3.6:27b
VOICEVOX_BASE_URL=http://127.0.0.1:50021

# Rate limiting
GENERATE_RATE_LIMIT=5/minute

# VOICEVOX speakers (speaker ID for male/female voices)
VOICEVOX_SPEAKER_MALE=21
VOICEVOX_SPEAKER_FEMALE=20
