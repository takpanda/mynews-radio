# App
APP_ENV=development
API_PORT=8000
WEB_PORT=3000

# Cron (daily batch) - format: minute hour day-of-month month day-of-week (UTC)
CRON_SCHEDULE=0 21 * * *

# Backend
DATABASE_URL=sqlite:////app/data/mynews-radio.db
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_BASE=http://pi5-3.local:8000

# External services (DGX side)
DGX_HOST=127.0.0.1
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3.6:27b
VOICEVOX_BASE_URL=http://127.0.0.1:50021

# VOICEVOX speakers (speaker ID for male/female voices)
VOICEVOX_SPEAKER_MALE=0
VOICEVOX_SPEAKER_FEMALE=1
